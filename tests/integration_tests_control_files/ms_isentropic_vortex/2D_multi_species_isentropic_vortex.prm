# Listing of Parameters
# ---------------------

# Reference:
# Will Trojak and Tarik Dzanic. Positivity-preserving discontinuous spectral element methods for compressible multi-species flows. Computers & Fluids, page 106343, 2024.

# Number of dimensions
set dimension = 2

# Chemical species
set species = 2
set run_type = flow_simulation
set pde_type = real_gas
set chemistry_input_file = ../../chemistry_files/O2_N2.kinetics

set flux_nodes_type = GLL

# DG formulation
set use_weak_form = false
set non_physical_behavior = abort_run
set use_split_form = true
set two_point_num_flux_type = KG
set conv_num_flux = two_point_flux_with_lax_friedrichs_dissipation
set flux_reconstruction = cDG
set use_inverse_mass_on_the_fly = true

# Note: this was added to turn off check_same_coords() -- has no other function when dim!=1
set use_periodic_bc = true

# degree of freedom renumbering not necessary for explicit time advancement cases
set do_renumber_dofs = false

#limiter flags
subsection limiter
  set bound_preserving_limiter = positivity_preservingWang2012
  set min_density = 1e-13
  
  #set use_tvb_limiter = true
  #set max_delta_x = 0.000625
  #set tuning_parameter_for_each_state = 0,0,0,0
end

# ODE solver
subsection ODE solver
  #set output_solution_every_x_steps = 20
  set output_solution_every_dt_time_intervals = 0.25
  set initial_time_step = 0.0001
  set ode_output = quiet
  set ode_solver_type = runge_kutta
  set runge_kutta_method = ssprk3_ex
end

# freestream Mach number
subsection euler
  set mach_infinity = 0.4
end

subsection flow_solver
  set flow_case_type = multi_species_isentropic_vortex
  set poly_degree = 4
  set final_time = 20.0
  set adaptive_time_step = true
  set courant_friedrichs_lewy_number = 0.6
  #set constant_time_step = 0.005
  set output_restart_files = true
  set restart_files_directory_name = restart_files
  set output_restart_files_every_dt_time_intervals = 1.0
  subsection grid
    set grid_left_bound = -10.0
    set grid_right_bound = 10.0
    set number_of_grid_elements_per_dimension = 80
    subsection grid_rectangle
      set number_of_grid_elements_x = 80
      set number_of_grid_elements_y = 80
      set grid_bottom_bound = -10.0
      set grid_top_bound = 10.0
    end
  end
end
