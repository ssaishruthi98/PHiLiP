# Listing of Parameters
# ---------------------
set test_type = viscous_shock_tube

# Number of dimensions
set dimension = 1

set pde_type = navier_stokes

# DG formulation
set use_weak_form = false

set flux_nodes_type = GLL
#set do_renumber_dofs = false

# Strong DG - LaxF
#set use_split_form = false
#set conv_num_flux = roe

# NSFR - Ra
set use_split_form = true
set two_point_num_flux_type = Ra
set conv_num_flux = two_point_flux_with_roe_dissipation
set flux_reconstruction = cDG
set use_inverse_mass_on_the_fly = true

subsection limiter
  set bound_preserving_limiter = positivity_preservingWang2012
  set min_density = 1e-13

  set use_OOA = true
end

# ODE solver
subsection ODE solver
  set ode_output = verbose
  set ode_solver_type = runge_kutta
  set print_iteration_modulo = 10
  set initial_time_step = 0.001
  #set output_solution_every_x_steps = 5
  set output_solution_every_dt_time_intervals = 0.1
  set runge_kutta_method = ssprk3_ex
end

# freestream Mach number
subsection euler
  set mach_infinity = 20.0
  set custom_boundary_for_each_state = 1.0,1.2,0.00178571,0,0
end

subsection navier_stokes
  set prandtl_number = 0.75
  set use_constant_viscosity = true
  set nondimensionalized_constant_viscosity = 0.001
end

subsection flow_solver
  set flow_case_type = viscous_shock_tube
  set poly_degree = 3
  set final_time = 1.0
  set adaptive_time_step = true
  set courant_friedrichs_lewy_number = 0.5
  set unsteady_data_table_filename = vst_energy
  subsection grid
    set number_of_mesh_refinements = 0
    subsection positivity_preserving_tests
      set vst_rho_0 = 1.0
      set vst_v_0 = 1.0
      set vst_v_inf = 0.2
    end
  end
end

subsection manufactured solution convergence study
  set use_manufactured_source_term = false
  set number_of_grids = 10
end
