# Listing of Parameters
# ---------------------
# Number of dimensions

set dimension = 2
set run_type = integration_test
set pde_type = navier_stokes
set test_type = viscous_shock_tube

# DG formulation
set use_weak_form = false
set flux_nodes_type = GLL

# Strong DG - LaxF
#set use_split_form = false
#set conv_num_flux = lax_friedrichs

# NSFR - Ra
set use_split_form = true
set two_point_num_flux_type = Ra
set conv_num_flux = two_point_flux_with_roe_dissipation
set flux_reconstruction = cDG
set use_inverse_mass_on_the_fly = true

# - additional parameters that do not ever change for this case
set use_curvilinear_split_form = false
set use_weight_adjusted_mass = false
set flux_reconstruction_aux = kPlus
set all_boundaries_are_periodic = false
set diss_num_flux = symm_internal_penalty
set do_renumber_dofs = false

subsection limiter
  set bound_preserving_limiter = positivity_preservingWang2012
  set min_density = 1e-13

  set use_OOA = true
end

# ODE solver
subsection ODE solver
  set ode_output = verbose
  set ode_solver_type = runge_kutta
  set initial_time_step = 0.00000001
  #set output_solution_every_x_steps = 5
  set runge_kutta_method = ssprk3_ex
  set print_iteration_modulo = 1
  set output_solution_every_dt_time_intervals = 0.1
end

# freestream Mach number
subsection euler
  set mach_infinity = 2.5
  set gamma_gas = 1.4
  #set custom_boundary_for_each_state = 1.0,1.2,0.00178571428571429,0,0 # Mach 20
  set custom_boundary_for_each_state = 1.0,1.2,0.0793650793650794,0,0  # Mach 3
end

# freestream Reynolds number and Prandtl number
subsection navier_stokes
  set prandtl_number = 0.75
  set reynolds_number_inf = 10.0
  set thermal_boundary_condition_type = isothermal
  set use_constant_viscosity = true
  set nondimensionalized_constant_viscosity = 0.01 # Mach 3
end

subsection flow_solver
  set flow_case_type = viscous_shock_tube
  set poly_degree = 2
  set final_time = 1.0
  set courant_friedrichs_lewy_number = 0.4
  set adaptive_time_step = true
  #set constant_time_step = 0.001
  set unsteady_data_table_filename = vst_energy
  subsection viscous_shock_tube
    set vst_rho_0 = 1.0
    set vst_v_0 = 1.0
    set vst_v_inf = 0.2
  end
  subsection grid
    set number_of_mesh_refinements = 0
  end
  set apply_initial_condition_method = interpolate_initial_condition_function
end

subsection manufactured solution convergence study
  set use_manufactured_source_term = false
  set number_of_grids = 10
end
